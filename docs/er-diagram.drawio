<mxfile host="app.diagrams.net" modified="2025-03-09T00:00:00.000Z" agent="Cursor" version="22.1.0" etag="er-youtube-comment-reader" type="device">
  <diagram name="ER - YouTube Comment Reader" id="er-diagram">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="920" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Coluna esquerda: Video, YouTubeSearchItem, Cache -->
        <mxCell id="video" value="&lt;b&gt;Video&lt;/b&gt;&lt;hr&gt;videoId (PK)&lt;br&gt;title&lt;br&gt;channelId&lt;br&gt;description&lt;br&gt;publishedAt&lt;br&gt;channelTitle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="170" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="searchitem" value="&lt;b&gt;YouTubeSearchItem&lt;/b&gt;&lt;hr&gt;id.videoId&lt;br&gt;snippet (title, channelId,&lt;br&gt;description, publishedAt)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="170" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="cache" value="&lt;b&gt;Cache&lt;/b&gt;&lt;hr&gt;key (PK)&lt;br&gt;expireAt (TTL)&lt;br&gt;data (JSON)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="335" width="170" height="75" as="geometry"/>
        </mxCell>

        <!-- Coluna central: CommentThread, Comment -->
        <mxCell id="commentthread" value="&lt;b&gt;CommentThread&lt;/b&gt;&lt;hr&gt;id (PK)&lt;br&gt;videoId (FK)&lt;br&gt;totalReplyCount&lt;br&gt;canReply&lt;br&gt;isPublic" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="170" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="comment" value="&lt;b&gt;Comment&lt;/b&gt;&lt;hr&gt;id (PK)&lt;br&gt;parentId (FK, opcional)&lt;br&gt;textOriginal&lt;br&gt;authorDisplayName&lt;br&gt;likeCount&lt;br&gt;publishedAt" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="170" height="115" as="geometry"/>
        </mxCell>

        <!-- Coluna direita: CommentFavorite, Favorites (mais afastada para evitar sobreposição) -->
        <mxCell id="commentfavorite" value="&lt;b&gt;CommentFavorite&lt;/b&gt;&lt;hr&gt;videoId (FK)&lt;br&gt;videoTitle&lt;br&gt;comment (ref)&lt;br&gt;replies (ref)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
